amends "pkl:base"

import* "./*.pkl" as fragments

local settings: Dynamic = new Dynamic {
  settingsVersion = 59
  bar = fragments["./bar.pkl"].bar
  general = fragments["./general.pkl"].general
  ui = fragments["./ui.pkl"].ui
  location = fragments["./location.pkl"].location
  calendar = fragments["./calendar.pkl"].calendar
  wallpaper = fragments["./wallpaper.pkl"].wallpaper
  appLauncher = fragments["./app-launcher.pkl"].appLauncher
  controlCenter = fragments["./control-center.pkl"].controlCenter
  dock = fragments["./dock.pkl"].dock
  colorSchemes = fragments["./color-schemes.pkl"].colorSchemes
  templates = fragments["./templates.pkl"].templates
  plugins = fragments["./plugins.pkl"].plugins
}

output {
  renderer = new JsonRenderer {}
  value = settings
}
