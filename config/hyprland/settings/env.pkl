open module env
import ".../libs/hyprlang.pkl" as r

envNodes: Listing<r.HyprNode> = new {
  // nvidia
  new { name = "env"; value = "LIBVA_DRIVER_NAME,nvidia" }
  new { name = "env"; value = "GBM_BACKEND,nvidia-drm" }
  new { name = "env"; value = "__GLX_VENDOR_LIBRARY_NAME,nvidia" }
  new { name = "env"; value = "NVD_BACKEND,direct" }
  // wayland
  new { name = "env"; value = "GDK_BACKEND,wayland,x11,*" }
  new { name = "env"; value = "QT_QPA_PLATFORM,wayland;xcb" }
  new { name = "env"; value = "SDL_VIDEODRIVER,wayland" }
  new { name = "env"; value = "MOZ_ENABLE_WAYLAND,1" }
  new { name = "env"; value = "ELECTRON_OZONE_PLATFORM_HINT,auto" }
  // cursor
  new { name = "env"; value = "XCURSOR_THEME,@xcursorTheme@" }
  new { name = "env"; value = "XCURSOR_SIZE,@xcursorSize@" }
}
