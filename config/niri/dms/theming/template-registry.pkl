amends "pkl:base"

import ".../common/theming/matugen.pkl" as matugen
import ".../libs/toml.pkl" as toml
import ".../config.pkl" as cfg

local home = "/home/\(cfg.username)"
local templateDir = "\(home)/.config/matugen/templates"

output {
  renderer = new matugen.PreambleRenderer {
    inner = new toml.Renderer {}
  }
  value = new Mapping {
    ["templates"] = new Mapping {
      ["kitty-dms-colors"] = new Mapping {
        ["input_path"]  = "\(templateDir)/kitty-dms-colors.conf"
        ["output_path"] = "\(home)/.config/kitty/dms-colors.conf"
        ["post_hook"]   = "/run/current-system/sw/bin/pkill -USR1 kitty 2>/dev/null; true"
      }
      ["niri-dms-colors"] = new Mapping {
        ["input_path"]  = "\(templateDir)/niri-dms-colors.kdl"
        ["output_path"] = "\(home)/.config/niri/dms-colors.kdl"
        ["post_hook"]   = "true"
      }
      ["lualine-dms-colors"] = new Mapping {
        ["input_path"]  = "\(templateDir)/lualine-dms-colors.lua"
        ["output_path"] = "\(home)/.config/nvim/lualine-dms-colors.lua"
        ["post_hook"]   = #"bash -c 'for f in /run/user/$(id -u)/nvim.*.0; do nvim --server "$f" --remote-send "<cmd>source ~/.config/nvim/lualine-dms-colors.lua<cr>" 2>/dev/null; done; true'"#
      }
      ["nvim-dms-colors"] = new Mapping {
        ["input_path"]  = "\(templateDir)/nvim-dms-colors.lua"
        ["output_path"] = "\(home)/.config/nvim/nvim-dms-colors.lua"
        ["post_hook"]   = #"bash -c 'for f in /run/user/$(id -u)/nvim.*.0; do nvim --server "$f" --remote-send "<cmd>source ~/.config/nvim/nvim-dms-colors.lua<cr>" 2>/dev/null; done; true'"#
      }
      ["foot-dms-colors"] = new Mapping {
        ["input_path"]  = "\(templateDir)/foot-dms-colors.ini"
        ["output_path"] = "\(home)/.config/foot/foot-dms-colors.ini"
        ["post_hook"]   = "true"
      }
      ["zed-dms-colors"] = new Mapping {
        ["input_path"]  = "\(templateDir)/zed-theme.json"
        ["output_path"] = "\(home)/.config/zed/themes/dms.json"
        ["post_hook"]   = "true"
      }
      ["satty-dms-colors"] = new Mapping {
        ["input_path"]  = "\(templateDir)/satty.css"
        ["output_path"] = "\(home)/.config/satty/overrides.css"
        ["post_hook"]   = "true"
      }
      ["ghostty-dms-colors"] = new Mapping {
        ["input_path"]  = "\(templateDir)/ghostty-colors"
        ["output_path"] = "\(home)/.config/ghostty/dms-colors"
        ["post_hook"]   = "true"
      }
    }
  }
}
