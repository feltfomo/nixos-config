open module bar

import "monitors.pkl" as mon

// Type aliases
typealias ColorMode       = "primary" | "default" | "surfaceText" | "outline" | "none" | "sch" | "inherit"
typealias FillMode        = "Fill" | "Fit" | "Stretch" | "Tile" | "Center"
typealias ScrollBehavior  = "column" | "workspace" | "none"
typealias ShadowDirection = "top" | "bottom" | "left" | "right"

// Bar widget classes
open class BarWidget {
  id:      String
  enabled: Boolean = true
}

class ClockWidget extends BarWidget { id = "clock" }

class ControlCenterButton extends BarWidget {
  id = "controlCenterButton"
  showAudioPercent: Boolean = false
  showMicIcon:      Boolean = false
  showMicPercent:   Boolean = false
}

class CpuTempWidget   extends BarWidget { id = "cpuTemp";   minimumWidth: Boolean = true }
class CpuUsageWidget  extends BarWidget { id = "cpuUsage";  minimumWidth: Boolean = true }
class MemUsageWidget  extends BarWidget { id = "memUsage";  minimumWidth: Boolean = true; showInGb: Boolean = false }
class DiskUsageWidget extends BarWidget { id = "diskUsage"; mountPath: String = "/"; diskUsageMode: Int = 0 }

function widget(widgetId: String): BarWidget = new BarWidget { id = widgetId }
function ccTile(widgetId: String) = new { id = widgetId; enabled = true; width = 50 }

// Shared bar defaults
// local — only used for amending below, not emitted to output.
local bar_base = new {
  enabled            = true
  autoHide           = false
  autoHideDelay      = 250
  bottomGap          = 0
  innerPadding       = 4
  noBackground       = false
  openOnOverview     = false
  visible            = true
  transparency       = 0.49
  widgetTransparency = 0
  borderEnabled      = false
  borderColor        = "surfaceText"
  borderOpacity      = 1.0
  borderThickness    = 1
  fontScale          = 1.0
  gothCornerRadiusOverride = false
  gothCornerRadiusValue    = 12
  popupGapsAuto      = true
  popupGapsManual    = 4
}

// Bar configs
barConfigs = new Listing {

  // Main bar — all screens
  (bar_base) {
    id   = "default"
    name = "Main Bar"
    position          = 0
    screenPreferences = new Listing { "all" }
    showOnLastDisplay = true
    leftWidgets   = new Listing { "launcherButton"; "workspaceSwitcher"; "focusedWindow" }
    centerWidgets = new Listing { new ClockWidget {} }
    rightWidgets  = new Listing {
      "systemTray"
      "notificationButton"
      "battery"
      new ControlCenterButton {}
    }
    spacing            = 4
    squareCorners      = false
    gothCornersEnabled = false
  }

  // Bar 2 — secondary display only
  (bar_base) {
    id   = "bar1776217847984"
    name = "Bar 2"
    position          = 1
    screenPreferences = mon.secondary
    showOnLastDisplay = false
    leftWidgets = new Listing {
      new CpuTempWidget {}
      new DiskUsageWidget {}
      new MemUsageWidget {}
      new CpuUsageWidget {}
    }
    centerWidgets = new Listing { "music" }
    rightWidgets  = new Listing {
      widget("privacyIndicator")
      widget("clipboardPlus")
      widget("colorPicker")
      widget("powerMenuButton")
      widget("appsDock")
    }
    spacing               = 0
    squareCorners         = true
    gothCornersEnabled    = true
    iconScale             = 1.0
    widgetOutlineEnabled  = false
    widgetOutlineColor    = "primary"
    widgetOutlineOpacity  = 1.0
    widgetOutlineThickness = 1
    widgetPadding         = 8
    maximizeDetection     = true
    maximizeWidgetIcons   = false
    maximizeWidgetText    = false
    removeWidgetPadding   = false
    showOnWindowsOpen     = false
    scrollEnabled         = true
    scrollXBehavior       = "column"
    scrollYBehavior       = "workspace"
    shadowIntensity       = 0
    shadowOpacity         = 60
    shadowDirectionMode   = "inherit"
    shadowDirection       = "top"
    shadowColorMode       = "default"
    shadowCustomColor     = "#000000"
  }
}

// Widget visibility
showLauncherButton      = true
showWorkspaceSwitcher   = true
showFocusedWindow       = true
showWeather             = true
showMusic               = true
showClipboard           = true
showCpuUsage            = true
showMemUsage            = true
showCpuTemp             = true
showGpuTemp             = true
selectedGpuIndex        = 0
enabledGpuPciIds        = new Listing {}
showSystemTray          = true
showClock               = true
showNotificationButton  = true
showBattery             = true
showControlCenterButton = true
showCapsLockIndicator   = true

// Control center
controlCenterShowNetworkIcon       = true
controlCenterShowBluetoothIcon     = true
controlCenterShowAudioIcon         = true
controlCenterShowAudioPercent      = false
controlCenterShowVpnIcon           = true
controlCenterShowBrightnessIcon    = false
controlCenterShowBrightnessPercent = false
controlCenterShowMicIcon           = false
controlCenterShowMicPercent        = false
controlCenterShowBatteryIcon       = false
controlCenterShowPrinterIcon       = false
controlCenterShowScreenSharingIcon = true
controlCenterWidgets = new Listing {
  ccTile("volumeSlider")
  ccTile("brightnessSlider")
  ccTile("wifi")
  ccTile("bluetooth")
  ccTile("audioOutput")
  ccTile("audioInput")
  ccTile("nightMode")
  ccTile("darkMode")
}

showPrivacyButton          = true
privacyShowMicIcon         = false
privacyShowCameraIcon      = false
privacyShowScreenShareIcon = false

// Media
mediaSize              = 1.0
waveProgressEnabled    = true
scrollTitleEnabled     = true
audioVisualizerEnabled = true
audioScrollMode        = "volume"
audioWheelScrollAmount = 5
